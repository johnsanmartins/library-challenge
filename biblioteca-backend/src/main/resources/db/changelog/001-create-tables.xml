<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
    xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.27.xsd">

    <changeSet id="001-create-categories" author="azurian">
        <createTable tableName="categories">
            <column name="id" type="BIGSERIAL">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="name" type="VARCHAR(100)">
                <constraints nullable="false" unique="true"/>
            </column>
            <column name="description" type="VARCHAR(500)"/>
        </createTable>
    </changeSet>

    <changeSet id="001-create-authors" author="azurian">
        <createTable tableName="authors">
            <column name="id" type="BIGSERIAL">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="first_name" type="VARCHAR(100)">
                <constraints nullable="false"/>
            </column>
            <column name="last_name" type="VARCHAR(100)">
                <constraints nullable="false"/>
            </column>
            <column name="nationality" type="VARCHAR(100)"/>
            <column name="birth_date" type="DATE"/>
        </createTable>
    </changeSet>

    <changeSet id="001-create-books" author="azurian">
        <createTable tableName="books">
            <column name="id" type="BIGSERIAL">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="title" type="VARCHAR(255)">
                <constraints nullable="false"/>
            </column>
            <column name="isbn" type="VARCHAR(20)">
                <constraints unique="true"/>
            </column>
            <column name="published_year" type="INT"/>
            <column name="synopsis" type="VARCHAR(1000)"/>
            <column name="available_copies" type="INT" defaultValueNumeric="1">
                <constraints nullable="false"/>
            </column>
            <column name="category_id" type="BIGINT">
                <constraints foreignKeyName="fk_books_category"
                             references="categories(id)"/>
            </column>
        </createTable>
    </changeSet>

    <changeSet id="001-create-book-authors" author="azurian">
        <createTable tableName="book_authors">
            <column name="book_id" type="BIGINT">
                <constraints nullable="false"
                             foreignKeyName="fk_book_authors_book"
                             references="books(id)"/>
            </column>
            <column name="author_id" type="BIGINT">
                <constraints nullable="false"
                             foreignKeyName="fk_book_authors_author"
                             references="authors(id)"/>
            </column>
        </createTable>
        <addPrimaryKey tableName="book_authors" columnNames="book_id, author_id"/>
    </changeSet>

    <changeSet id="001-create-clients" author="azurian">
        <createTable tableName="clients">
            <column name="id" type="BIGSERIAL">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="first_name" type="VARCHAR(100)">
                <constraints nullable="false"/>
            </column>
            <column name="last_name" type="VARCHAR(100)">
                <constraints nullable="false"/>
            </column>
            <column name="email" type="VARCHAR(150)">
                <constraints nullable="false" unique="true"/>
            </column>
            <column name="phone" type="VARCHAR(20)"/>
            <column name="registration_date" type="DATE">
                <constraints nullable="false"/>
            </column>
        </createTable>
    </changeSet>

    <changeSet id="001-create-loans" author="azurian">
        <createTable tableName="loans">
            <column name="id" type="BIGSERIAL">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="book_id" type="BIGINT">
                <constraints nullable="false"
                             foreignKeyName="fk_loans_book"
                             references="books(id)"/>
            </column>
            <column name="client_id" type="BIGINT">
                <constraints nullable="false"
                             foreignKeyName="fk_loans_client"
                             references="clients(id)"/>
            </column>
            <column name="loan_date" type="DATE">
                <constraints nullable="false"/>
            </column>
            <column name="due_date" type="DATE">
                <constraints nullable="false"/>
            </column>
            <column name="return_date" type="DATE"/>
            <column name="status" type="VARCHAR(20)" defaultValue="ACTIVE">
                <constraints nullable="false"/>
            </column>
        </createTable>
    </changeSet>

</databaseChangeLog>
